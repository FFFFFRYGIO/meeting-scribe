# Byte-compiled / optimized / cache files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
wheels/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Type checker / test / coverage caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Secrets — never commit real tokens/keys
.env
.env.local

# Editor / OS noise
.idea/
.vscode/
.DS_Store
Thumbs.db

# Whisper model cache (downloaded on first run)
*.bin

# Project input/output media — keep the folders, ignore their contents
data/*
!data/.gitkeep
results/*
!results/.gitkeep
