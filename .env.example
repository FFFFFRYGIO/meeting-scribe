# Copy to .env and fill in. NEVER commit the real .env.

# Required for summaries and Q&A (Claude).
ANTHROPIC_API_KEY=sk-ant-...

# Enables the Discord bot. Leave unset to run the web UI only.
DISCORD_BOT_TOKEN=

# Web server port (Coolify maps this).
PORT=8000

# Single-account login for the web UI (HTTP Basic). Leave AUTH_PASSWORD unset to
# disable the login (e.g. local dev).
AUTH_USERNAME=
AUTH_PASSWORD=
